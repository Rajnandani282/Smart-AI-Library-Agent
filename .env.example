# ─────────────────────────────────────────────────────────────────────────────
#  IBM watsonx.ai credentials  –  copy this file to .env and fill in values
# ─────────────────────────────────────────────────────────────────────────────

# IBM Cloud API Key  (IAM key from cloud.ibm.com → Manage → Access → API keys)
IBM_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID  (from watsonx.ai → Projects → <your project> → Manage)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai URL  (region-specific endpoint)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ─────────────────────────────────────────────────────────────────────────────
#  Application settings
# ─────────────────────────────────────────────────────────────────────────────

# Flask secret key  (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change_this_to_a_random_secret_key

# Set to "development" for debug mode, "production" for deployment
FLASK_ENV=development

# Vector store backend: "chroma" or "faiss"
VECTOR_STORE=chroma

# Embedding model to use from HuggingFace (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Granite LLM model ID on watsonx.ai
LLM_MODEL_ID=ibm/granite-13b-chat-v2

# Port to run on (5000 is often taken on Windows by AirPlay/other services)
PORT=5001

# ChromaDB persistence directory (relative to project root)
CHROMA_PERSIST_DIR=./vector_store/chroma_db

# FAISS index path (used when VECTOR_STORE=faiss)
FAISS_INDEX_PATH=./vector_store/faiss_index

# Library name shown in the UI
LIBRARY_NAME=University Central Library

# Maximum chunks retrieved per RAG query
RAG_TOP_K=6
